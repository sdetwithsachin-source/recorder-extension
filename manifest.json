{
    "manifest_version": 3,
    "name": "Playwright Recorder",
    "version": "1.0.0",
    "description": "Standalone Playwright Recorder",
    "permissions": [
        "activeTab",
        "scripting",
        "tabs",
        "storage",
        "downloads"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Playwright Recorder"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "styles.css",
                "recorder-ui.js",
                "content.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}